# =============================================
# Healthcare RAG System - Environment Variables
# =============================================

# Choose ONE provider and fill in the key:

# Option 1: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Option 2: Groq (free tier available at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Option 3: Gemini (free tier at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_gemini_api_key_here

# LLM Provider: "openai" | "groq" | "gemini"
LLM_PROVIDER=gemini

# Model names
OPENAI_MODEL=gpt-3.5-turbo
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chroma_db

# Dataset paths (place your CSVs here)
HEART_DISEASE_CSV=./data/heart.csv
DERMATOLOGY_CSV=./data/dermatology.csv
DIABETES_CSV=./data/diabetes.csv

# ──────────────────────────────────────────────
# NestJS backend integration
# ──────────────────────────────────────────────
# Must match the JWT_SECRET set in the NestJS backend .env.
# When set, all /chat and /Upload_File requests must carry a valid Bearer token.
# Leave empty to disable token validation (development only).
JWT_SECRET=your_nestjs_jwt_secret_here
JWT_ALGORITHM=HS256

# NestJS backend base URL (used for future direct API calls)
NESTJS_BACKEND_URL=http://localhost:3000
